{
  "expo": {
    "name": "ForEver",
    "slug": "forever",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "forever",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.forever.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "ForEver usa il microfono per registrare messaggi vocali",
        "NSPhotoLibraryUsageDescription": "ForEver accede alla galleria per caricare foto del profilo",
        "NSCameraUsageDescription": "ForEver usa la fotocamera per scattare foto profilo"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.forever.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        { "photosPermission": "ForEver accede alle tue foto per il profilo" }
      ],
      [
        "expo-av",
        { "microphonePermission": "ForEver usa il microfono per messaggi vocali" }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
